default_platform(:ios)

APP_IDENTIFIER = "com.github.jaramah.Welkin".freeze
TEAM_ID = "V5LHDBRQYB".freeze

platform :ios do
  desc "Build Welkin and upload it to TestFlight"
  lane :beta do
    # On CI, create a fresh throwaway keychain to hold signing assets.
    setup_ci
    require "base64"

    # Materialize the App Store Connect API key (.p8) from the base64 secret.
    key_path = File.absolute_path("AuthKey.p8")
    File.write(key_path, Base64.decode64(ENV.fetch("ASC_KEY_CONTENT")))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path
    )

    # Import the existing App Store distribution certificate (with its private
    # key) into the CI keychain. The account's distribution cert was created on
    # the user's Mac; without its private key here, export can't sign for the
    # App Store and Xcode falls back to cloud signing, which the API key's role
    # isn't allowed to do ("Cloud signing permission error"). With the cert
    # present, -allowProvisioningUpdates only needs to fetch the profiles.
    cert_path = File.absolute_path("dist_cert.p12")
    File.write(cert_path, Base64.decode64(ENV.fetch("ASC_DIST_CERT")))
    import_certificate(
      certificate_path: cert_path,
      certificate_password: ENV.fetch("ASC_DIST_CERT_PASSWORD", ""),
      keychain_name: ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_tmp_keychain"),
      keychain_password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", "")
    )

    # Next build number = whatever is already on TestFlight + 1, so uploads never
    # collide. This has to be resolved BEFORE xcodegen runs so the number can be
    # baked straight into the generated project.
    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    ).to_i + 1

    # Stamp it into project.yml. Passing CURRENT_PROJECT_VERSION as an xcargs
    # override alone was not enough: Info.plist processing resolved the version
    # from the project, so every archive carried the stale number and App Store
    # Connect rejected the upload as a duplicate. Writing it into the source of
    # truth that xcodegen reads makes the app and the widget agree by construction.
    project_yml = File.expand_path("../project.yml", __dir__)
    yaml = File.read(project_yml)
    yaml.sub!(/CURRENT_PROJECT_VERSION: ".*"/, %(CURRENT_PROJECT_VERSION: "#{next_build}"))
    File.write(project_yml, yaml)
    UI.message("Building as version #{next_build}")

    # Welkin.xcodeproj is generated from project.yml — regenerate it before building.
    Dir.chdir("..") { sh("xcodegen", "generate") }

    widget_identifier = "#{APP_IDENTIFIER}.WelkinWidget"

    # Create/download App Store provisioning profiles for the app and the widget,
    # using the same API key. Export can't be left to Xcode's cloud signing (the
    # key's role can't do it), so we hand it an explicit profile mapping instead.
    app_profile = get_provisioning_profile(
      api_key: api_key, app_identifier: APP_IDENTIFIER,
      provisioning_name: "Welkin CI App Store", force: true
    )
    widget_profile = get_provisioning_profile(
      api_key: api_key, app_identifier: widget_identifier,
      provisioning_name: "Welkin Widget CI App Store", force: true
    )

    # Pin BOTH targets to manual signing with the profiles above, and drop
    # -allowProvisioningUpdates. Left on automatic, the archive asked Xcode to mint
    # a fresh *development* certificate on every run; ephemeral runners can't reuse
    # them, so they piled up until the account hit Apple's certificate cap
    # ("Choose a certificate to revoke"). Manual signing creates nothing — it just
    # uses the distribution cert we imported and the profiles we downloaded.
    update_code_signing_settings(
      path: "Welkin.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      targets: ["Welkin"],
      bundle_identifier: APP_IDENTIFIER,
      profile_name: app_profile
    )
    update_code_signing_settings(
      path: "Welkin.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      targets: ["WelkinWidgetExtension"],
      bundle_identifier: widget_identifier,
      profile_name: widget_profile
    )

    build_app(
      project: "Welkin.xcodeproj",
      scheme: "Welkin",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build}",
      export_options: {
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          APP_IDENTIFIER => app_profile,
          widget_identifier => widget_profile
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true
    )
  end
end
